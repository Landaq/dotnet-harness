{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python \".codex/hooks/pre_tool_use_policy.py\"",
            "timeout": 20,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python \".codex/hooks/post_tool_use_review.py\"",
            "timeout": 20,
            "statusMessage": "Reviewing command result"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \".codex/hooks/stop_summary.py\"",
            "timeout": 20,
            "statusMessage": "Preparing final safety summary"
          }
        ]
      }
    ]
  }
}
